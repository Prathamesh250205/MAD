<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notification Demo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btn_send_basic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send Basic Notification"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_send_big_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send Big Text Notification"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_send_heads_up"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send Heads-Up Notification"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancel Notification"
        style="@style/Widget.AppCompat.Button.Colored" />

</LinearLayout>